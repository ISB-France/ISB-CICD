# Woodpecker host (public URL)
WOODPECKER_HOST=http://votre-serveur-ip

# GitHub OAuth App credentials
# Créer une app OAuth sur GitHub : Settings > Developer settings > OAuth Apps
GITHUB_CLIENT_ID=votre_github_client_id
GITHUB_CLIENT_SECRET=votre_github_client_secret

# Secret partagé entre server et agent (generer avec: openssl rand -hex 32)
WOODPECKER_AGENT_SECRET=votre_secret_tres_long_32_hex

# Admin GitHub username (peut gérer Woodpecker)
WOODPECKER_ADMIN=votre_login_github

# Nombre max de pipelines en parallèle par agent
WOODPECKER_MAX_WORKFLOWS=2

# Database (sqlite3 par defaut, ou postgres)
# WOODPECKER_DATABASE_DRIVER=postgres
# WOODPECKER_DATABASE_DATASOURCE=postgres://user:pass@host:5432/woodpecker?sslmode=disable
